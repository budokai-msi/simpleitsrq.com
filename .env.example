# simpleitsrq-web — required env vars
#
# Copy this file to .env.local for local development and fill in the values.
# Production values live in the Vercel dashboard:
#   https://vercel.com/dashboard → simpleitsrq-com → Settings → Environment Variables
#
# Several of these are provisioned automatically when you run:
#   vercel integration add neon
#   vercel env pull .env.local --yes
#
# Never commit .env.local — it's already in .gitignore.
#
# =====================================================================
#   SENSITIVITY MARKINGS (Vercel env-var types)
# =====================================================================
# The April 2026 Vercel breach decrypted every non-"Sensitive"-typed
# env var for affected projects. Going forward, every row below marked
# [SENSITIVE] MUST be added to Vercel with the Sensitive toggle ON.
# See SECURITY.md at the repo root for the full incident writeup +
# rotation runbook.
#
#   [SENSITIVE]  → secret; mark Sensitive in Vercel, rotate if leaked
#   [PUBLIC]     → VITE_* prefix; shipped to the client bundle by
#                  design — safe to leave non-sensitive
#   [PUBLIC-OK]  → technically secret but low-impact if leaked
# =====================================================================

# --- Resend (transactional email) ---  [SENSITIVE]
# Sends the contact form payload to hello@simpleitsrq.com.
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# --- Cloudflare Turnstile (captcha) ---  [SENSITIVE] (secret) + [PUBLIC] (site key)
# Server-side secret used to verify submission tokens.
# Dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# Public site key used by the Turnstile widget in the browser.
# The VITE_ prefix exposes it to the client bundle — this key IS meant to be public.
VITE_TURNSTILE_SITE_KEY=0x0000000000000000000000000000000000000000

# --- Contact inbox destination (optional) ---
# Overrides the "to" address for contact form and ticket submissions.
# Defaults to hello@simpleitsrq.com. Set to a real mailbox (e.g. a Gmail
# address) until the apex MX records for simpleitsrq.com are configured.
# CONTACT_TO_EMAIL=you@example.com

# --- Cal.com inline booking (public) ---
# Full Cal.com path in the form "handle/event-slug".
# Dashboard: https://app.cal.com/event-types
# Example: simpleitsrq/free-consultation
# The VITE_ prefix exposes it to the client bundle — this value IS public.
# Leave empty until you finish Cal.com setup; the /book page will show a
# "coming soon" placeholder with an email fallback.
VITE_CALCOM_CAL_LINK=

# --- Neon Postgres (client portal DB) ---
# Provisioned automatically by:
#   vercel integration add neon
# You get DATABASE_URL (pooled) and DATABASE_URL_UNPOOLED + a bunch of
# POSTGRES_* / PG* aliases. The portal code reads DATABASE_URL.
# Apply the schema with:
#   node --env-file=.env.local scripts/db/push.mjs
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# [SENSITIVE] Rotate the role password in Neon Console if exposed.

# --- Session signing ---  [SENSITIVE]
# Random 32-byte base64url secret, used to sign session cookies / CSRF state.
# Rotating AUTH_SECRET invalidates every live signed-in session — that's
# the desired behavior post-compromise.
# Generate one with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=replace_with_random_32_bytes_base64url

# --- Canonical app URL ---
# Used when building OAuth redirect_uri. Optional — if unset, the server
# falls back to the Host header from the incoming request. Set this in
# production to avoid tampering.
#   Local dev:   http://localhost:3000
#   Production:  https://simpleitsrq.com
APP_URL=https://simpleitsrq.com

# --- Google OAuth client ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID.
# App type: Web application.
# Authorized redirect URI:
#   https://simpleitsrq.com/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google    (add for local dev)
GOOGLE_CLIENT_ID=your_google_client_id_here
# [SENSITIVE]
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- Auth0 Universal Login (enterprise SSO — Okta, Azure AD, Ping, etc.) ---
# Auth0 Application → Settings → Basic Information.
# Application type: Regular Web Application.
# Allowed Callback URLs:
#   https://simpleitsrq.com/api/auth/callback/auth0
#   http://localhost:3000/api/auth/callback/auth0    (add for local dev)
# Allowed Logout URLs:
#   https://simpleitsrq.com/portal
#   http://localhost:3000/portal    (add for local dev)
#
# To connect Okta specifically:
#   1. In Auth0 dashboard → Authentication → Enterprise → Okta → Create Connection
#   2. Enter your Okta domain (e.g. yourcompany.okta.com)
#   3. Set AUTH0_CONNECTION=okta below (or leave empty for Universal Login page)
AUTH0_CLIENT_ID=
# [SENSITIVE]
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=your-tenant.auth0.com
# Optional: pin to a specific IdP connection (e.g. "okta", "azure-ad").
# Leave empty to show Auth0 Universal Login with all enabled connections.
# AUTH0_CONNECTION=okta

# --- GitHub OAuth app ---
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App.
# Homepage URL:           https://simpleitsrq.com
# Authorization callback: https://simpleitsrq.com/api/auth/callback/github
# (Create a second app for localhost if you want to test OAuth locally.)
GITHUB_CLIENT_ID=
# [SENSITIVE]
GITHUB_CLIENT_SECRET=

# --- GitHub content publishing (fine-grained PAT) ---
# Blog drafts produced by the cron agent are published by committing to
# src/data/posts.js via the GitHub Contents API. Needs a fine-grained
# personal access token scoped to the simpleitsrq.com repo with
# "Contents: read and write" permission.
# Create at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
# [SENSITIVE] Prefer a fine-grained token scoped to this single repo
# with only "Contents: read and write" — not a classic or full-scope PAT.

# --- Admin contact ---
# Email that receives operational alerts (cron failures, security events,
# new orphan tickets backfilled on sign-in). Also authorizes admin-only
# routes in the portal.
ADMIN_EMAIL=you@example.com

# --- Anthropic API key (Claude Haiku blog draft agent) ---
# Powers the daily cron that generates draft_posts rows from recent HN /
# news signals. The admin reviews drafts at /portal?tab=drafts and clicks
# Publish to commit via GITHUB_TOKEN.
# Dashboard: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here
# [SENSITIVE] This one bills real money. Set a hard spending limit in
# the Anthropic dashboard alongside rotation.

# --- Cron secret ---  [SENSITIVE]
# Shared secret verified by api/cron/* handlers. Vercel's cron scheduler
# passes it in the Authorization: Bearer <CRON_SECRET> header. Random
# 32-byte base64url value — generate with the same command as AUTH_SECRET.
CRON_SECRET=replace_with_random_32_bytes_base64url

# --- Stripe (invoice pipeline + payment links) ---  [SENSITIVE]
# LIVE mode secret key — the portal uses a two-step draft → review → send
# flow so no invoice is finalized without an explicit admin click.
# Rotating mid-cycle: Stripe honors old keys for a 7-day grace period,
# but inspect the last 90 days of events before disabling the old key.
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_key_here

# --- Store product buy links (one per product in src/data/products.js) ---
# Each is a Stripe Payment Link URL (https://buy.stripe.com/...) OR a
# Gumroad buy URL. When unset, the product renders an email-capture
# "waitlist" CTA instead of a buy button.
# Dashboard: https://dashboard.stripe.com/payment-links
VITE_PRODUCT_BUNDLE_BUY_URL=
VITE_PRODUCT_HIPAA_KIT_BUY_URL=
VITE_PRODUCT_WISP_BUY_URL=
VITE_PRODUCT_INSURANCE_KIT_BUY_URL=
VITE_PRODUCT_HURRICANE_KIT_BUY_URL=
VITE_PRODUCT_VENDOR_RISK_BUY_URL=
VITE_PRODUCT_BUDGET_CALENDAR_BUY_URL=
VITE_PRODUCT_INSURANCE_BINDER_BUY_URL=
VITE_PRODUCT_TABLETOP_KIT_BUY_URL=
VITE_PRODUCT_SAAS_IR_BUY_URL=
VITE_PRODUCT_ONBOARDING_KIT_BUY_URL=
VITE_PRODUCT_AI_POLICY_BUY_URL=

# --- Affiliate program IDs (VITE_ prefix exposes to client bundle) ---
# Only the ones with values will render links and show the FTC disclosure.
# Each maps to an entry in src/data/affiliates.js.
# Amazon Associates:
VITE_AFF_AMAZON_TAG=
# Gusto Payroll referral URL (e.g. https://gusto.com/r/yourcode):
VITE_AFF_GUSTO_REF=
# 1Password Business (PartnerStack):
VITE_AFF_1PASSWORD_REF=
# HoneyBook referral URL:
VITE_AFF_HONEYBOOK_REF=
# Acronis MSP partner link:
VITE_AFF_ACRONIS_REF=
# Ubiquiti UniFi Partner Program landing URL — drives the camera buyer's guide
# and any UniFi gear mention. Sign up: https://www.ui.com/partner-program/
VITE_AFF_UBNT_REF=
# Reolink affiliate (Impact) landing URL — drives the residential / Tier-1
# camera tier in the buyer's guide. Sign up: https://reolink.com/affiliate/
VITE_AFF_REOLINK_REF=
# B&H Photo Pro Affiliate — drives any AV / pro-networking gear that's
# better-priced at B&H than at Amazon. Sign up: https://bhphotovideo.com/affiliates
VITE_AFF_BH_REF=
# Backblaze Cloud Backup — drives the post-repair "set up off-machine backup"
# cross-sell. Sign up: https://www.backblaze.com/affiliates/
VITE_AFF_BACKBLAZE_REF=

# --- Live chat (Tawk.to free tier) ---
# When BOTH set, the chat widget loads on every page AFTER marketing-consent
# is granted in the cookie banner. When unset, no chat code ships at all
# (the visitor sees the contact form / phone number as the fallback).
# Find the IDs in https://dashboard.tawk.to → Administration → Channels →
# Chat Widget → Direct Chat Link. The URL ends in /<property>/<widget>.
VITE_TAWK_PROPERTY_ID=
VITE_TAWK_WIDGET_ID=

# --- Google Business Profile reviews ---
# Server-side only — DO NOT prefix with VITE_. The /api/reviews endpoint
# proxies Place Details with this key so the homepage shows live Google
# review text + the star rating without shipping the Google Maps JS SDK.
# Quota: 6h edge cache + 24h SWR means roughly 4 calls per day.
# Get a key at https://console.cloud.google.com/google/maps-apis (enable
# "Places API"). Get your Place ID at
# https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Cyber-insurance broker referral (passive income stream) ---
# Partner referral URL from Coalition, Cowbell, At-Bay, Resilience, etc.
# Typical payout is $300-$2,000 per bound policy plus renewal residuals.
# When unset, the /cyber-insurance-quote page falls back to a lead-capture
# form that emails hello@simpleitsrq.com — so the page earns leads even
# before the affiliate is approved. The public-facing copy renders the
# partner name verbatim; keep it short and customer-friendly.
VITE_CYBER_INSURANCE_PARTNER_URL=
VITE_CYBER_INSURANCE_PARTNER_NAME=

# --- Compliance audit referral (passive income stream) ---
# Referral URL from a SOC 2 / HIPAA / PCI / FTC Safeguards audit firm
# (Prescient Assurance, Drata + Prescient, AuditBoard partners, Compass
# IT Compliance, A-LIGN, etc.). Typical payout is $500-$2,000 per referred
# engagement, sometimes structured as 5-10% of the audit fee. When unset,
# the /compliance-audit-referral page renders a lead-capture form that
# emails hello@simpleitsrq.com — so the page earns leads before the
# partnership is signed. Per-audit-type URLs can be plugged into the
# per-type env vars below and the form will route to the matching partner
# based on the "which audit?" field selection. VITE_AUDIT_PARTNER_URL is
# the generic fallback used when no type-specific URL is configured.
VITE_AUDIT_PARTNER_URL=
VITE_AUDIT_PARTNER_NAME=
# Per-type overrides (optional). Leave blank to use the generic URL above.
VITE_AUDIT_PARTNER_SOC2_URL=
VITE_AUDIT_PARTNER_HIPAA_URL=
VITE_AUDIT_PARTNER_PCI_URL=
VITE_AUDIT_PARTNER_FTC_URL=

# --- Google AdSense (optional, enables ad slots + auto-ads) ---
# Publisher-side client ID in the "ca-pub-1234567890123456" format from
# the AdSense dashboard. src/components/AdSense.jsx uses it to load the
# pagead script + render AdUnit slots placed in blog posts and the blog
# index. Consent-gated: ads only render when the visitor accepts
# marketing cookies via the consent banner. When unset, AdUnit returns
# null (nothing rendered), so it's safe to leave blank until approval
# completes.
#
# Also remember to:
#   1. Replace `ca-pub-XXXXXXXXXXXXXXXX` in index.html's
#      <meta name="google-adsense-account"> with your publisher ID.
#   2. Replace `pub-XXXXXXXXXXXXXXXX` in public/ads.txt.
#   3. After deploy, verify the site in the AdSense dashboard (usually
#      takes 24-48 hours after ads.txt propagates).
VITE_ADSENSE_CLIENT=

# --- Google Analytics 4 (optional override) ---
# Measurement ID for GA4. public/ga-init.js has a hardcoded fallback
# so tracking works even when this is unset; set it here to point
# staging/dev at a test property without touching code. Consent Mode
# v2 is wired in src/lib/analytics.js — GA runs in cookieless-ping mode
# until the visitor opts in via the cookie banner.
VITE_GA_MEASUREMENT_ID=

# --- Microsoft Clarity (heatmaps + session recordings, optional) ---
# 10-character project ID from clarity.microsoft.com → Settings → Setup.
# Empty = feature disabled (script never injects). Clarity loads only
# after the visitor grants analytics consent — same gate as GA4.
# Free tier covers unlimited sessions; no card on file.
VITE_CLARITY_PROJECT_ID=

# --- Sentry (client-side error tracking, optional) ---
# Public DSN for the browser SDK. When unset, Sentry is a complete no-op —
# no network calls, no warnings, safe to leave blank in development.
# Dashboard: https://sentry.io → Project → Settings → Client Keys (DSN)
# The VITE_ prefix exposes it to the client bundle; DSNs are designed to
# be public (they identify the project, not authenticate writes).
VITE_SENTRY_DSN=
