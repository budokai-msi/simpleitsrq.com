{
  "name": "simpleitsrq-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-posts-meta.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-rss.mjs && node scripts/generate-og-images.mjs && node scripts/generate-city-og-images.mjs && node scripts/generate-industry-og-images.mjs",
    "build": "vite build && node scripts/generate-blog-stubs.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ci:install": "npm ci",
    "generate:images": "node scripts/generate-images.mjs",
    "benchmark:scan": "node scripts/benchmark/run-batch-scan.mjs",
    "benchmark:report": "node scripts/benchmark/generate-report.mjs",
    "db:push": "node --env-file=.env.local scripts/db/push.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.1.0",
    "@sentry/react": "10.67.0",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "botid": "1.5.11",
    "jose": "6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "1.25.0",
    "nodemailer": "^9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "resend": "6.17.2",
    "stripe": "22.3.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@mdx-js/rollup": "3.1.1",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "gray-matter": "4.0.3",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "sharp": "0.35.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "svix": "1.92.2"
  }
}
